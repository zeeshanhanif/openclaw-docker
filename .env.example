# OpenClaw Gateway Token
# Generated during onboarding: docker compose run --rm --profile cli openclaw-cli onboard
OPENCLAW_GATEWAY_TOKEN=

# OpenAI API Key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Anthropic API Key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# Timezone (default: UTC)
# Examples: America/New_York, Europe/London, Asia/Karachi
OPENCLAW_TZ=UTC
